generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum SubmissionStatus {
  SUBMITTED
  NOTSUBMITTED
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
}

model User {
  id        Int      @id @default(autoincrement())
  role      Role
  password  String
  createdAt DateTime @default(now())
}

model Project {
  id               Int      @id @default(autoincrement())
  projectName      String
  projectCode      String   @unique
  receiptNo        String
  totalAmount      Int
  perSurgeryAmount Int
  balanceSurgery   Int

  
  totalSurgeries   Int      @default(0)
  completedCount   Int      @default(0)
  status           ProjectStatus   @default(ACTIVE)
  submitted        SubmissionStatus @default(NOTSUBMITTED)

  surgeries        Surgery[]
  batches          Batch[]

  createdAt        DateTime @default(now())
}


model Surgery {
  id             Int      @id @default(autoincrement())
  srNo           Int
  mrdNo          String
  patientName    String
  address        String?
  operatedEye    String
  age            Int
  sex            String
  dateOfSurgery  DateTime
  contactNo      String
  surgeryName    String
  surgeryCategory  String?  // Adult / Pediatric / NULL
  donorName      String

  projectId      Int
  project        Project  @relation(fields: [projectId], references: [id])

  batchId        String
  batch          Batch    @relation("BatchSurgeries", fields: [batchId], references: [id])
  createdAt      DateTime @default(now())
}


model Batch {
  id               String @id @default(uuid())
  projectId        Int
  project          Project @relation(fields: [projectId], references: [id])

  batchDate        DateTime
  completedCount   Int
  incompleteCount  Int

  excelPath        String
  zipPath          String

  createdBy        Int  // userId
  createdAt        DateTime @default(now())

  surgeries        Surgery[] @relation("BatchSurgeries")
 }